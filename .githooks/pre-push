#!/usr/bin/env bash
#
# pre-push hook — reject direct pushes to protected branches (main/master).
# Steers contributors to a feature branch + pull request.
#
# Enabled via `git config core.hooksPath .githooks` (npm install does this
# automatically through the "prepare" script in package.json).
#
# Escape hatches (use sparingly):
#   ALLOW_PUSH_TO_MAIN=1 git push ...     # one-off override
#   git push --no-verify ...              # skips all pre-push hooks
#
# git passes matched refs on stdin:  <local ref> <local sha> <remote ref> <remote sha>
set -euo pipefail

protected_re='^refs/heads/(main|master)$'
blocked=0

while read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_ref" =~ $protected_re ]]; then
    branch="${remote_ref#refs/heads/}"
    echo "✗ Direct push to '$branch' is blocked." >&2
    echo "  Use a feature branch and open a PR:" >&2
    echo "    git checkout -b <type>/<slug> && git push -u origin <branch> && gh pr create" >&2
    blocked=1
  fi
done

if [[ "$blocked" == 1 && "${ALLOW_PUSH_TO_MAIN:-}" != "1" ]]; then
  echo "  (override once: ALLOW_PUSH_TO_MAIN=1 git push ...  |  git push --no-verify)" >&2
  exit 1
fi

exit 0
